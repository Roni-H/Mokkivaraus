<?xml version="1.0" encoding="utf-8" ?>
<Application
    x:Class="MokkiVaraus_MAUI.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="PrimaryColor">#1F4E79</Color>
            <Color x:Key="SecondaryColor">#2D6A4F</Color>
            <Color x:Key="AccentColor">#E9C46A</Color>
            <Color x:Key="SurfaceColor">#F4F7FB</Color>
            <Color x:Key="CardColor">#FFFFFF</Color>
            <Color x:Key="TextColor">#1D2433</Color>
            <Color x:Key="MutedTextColor">#64748B</Color>
            <Color x:Key="DangerColor">#B91C1C</Color>
            <Color x:Key="SuccessColor">#0F766E</Color>

            <Style TargetType="ContentPage">
                <Setter Property="BackgroundColor" Value="{StaticResource SurfaceColor}" />
            </Style>

            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource TextColor}" />
            </Style>

            <Style TargetType="Button">
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Padding" Value="16,12" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="BackgroundColor" Value="{StaticResource PrimaryColor}" />
                <Setter Property="TextColor" Value="White" />
            </Style>

            <Style TargetType="Entry">
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="TextColor" Value="{StaticResource TextColor}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource MutedTextColor}" />
                <Setter Property="HeightRequest" Value="48" />
            </Style>

            <Style TargetType="Picker">
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="TextColor" Value="{StaticResource TextColor}" />
                <Setter Property="HeightRequest" Value="48" />
            </Style>

            <Style TargetType="DatePicker">
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="TextColor" Value="{StaticResource TextColor}" />
                <Setter Property="HeightRequest" Value="48" />
            </Style>

            <Style TargetType="Frame">
                <Setter Property="BackgroundColor" Value="{StaticResource CardColor}" />
                <Setter Property="CornerRadius" Value="20" />
                <Setter Property="HasShadow" Value="True" />
                <Setter Property="Padding" Value="18" />
                <Setter Property="BorderColor" Value="#E2E8F0" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
