<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MokkiVaraus_MAUI.Views.CottagesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Mökit"
    BackgroundColor="{StaticResource SurfaceColor}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Mökkien hallinta" FontSize="26" FontAttributes="Bold" />
                    <Label Text="Hae, lisää ja rajaa vapaat mökit alueen, hinnan ja varusteiden perusteella." FontSize="13" TextColor="{StaticResource MutedTextColor}" />
                </VerticalStackLayout>
                <Button Grid.Column="1" Text="Päivitä" Command="{Binding RefreshCommand}" />
            </Grid>

            <Frame>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Haku ja suodatus" FontAttributes="Bold" FontSize="18" />
                    <Picker ItemsSource="{Binding Areas}" SelectedItem="{Binding FilterArea}" ItemDisplayBinding="{Binding Name}" Title="Alue" />
                    <Entry Text="{Binding FilterPriceText}" Placeholder="Enimmäishinta / yö" Keyboard="Numeric" />
                    <Entry Text="{Binding FilterEquipment}" Placeholder="Varusteet esim. sauna wifi" />
                    <DatePicker Date="{Binding AvailableFrom}" />
                    <DatePicker Date="{Binding AvailableTo}" />
                    <Button Text="Hae vapaat mökit" Command="{Binding SearchCommand}" />
                </VerticalStackLayout>
            </Frame>

            <Frame>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Mökin tiedot" FontAttributes="Bold" FontSize="18" />
                    <Picker ItemsSource="{Binding Areas}" SelectedItem="{Binding SelectedArea}" ItemDisplayBinding="{Binding Name}" Title="Valitse alue" />
                    <Entry Text="{Binding Name}" Placeholder="Mökin nimi" />
                    <Entry Text="{Binding Description}" Placeholder="Kuvaus" />
                    <Entry Text="{Binding CapacityText}" Placeholder="Henkilömäärä" Keyboard="Numeric" />
                    <Entry Text="{Binding PriceText}" Placeholder="Hinta / yö" Keyboard="Numeric" />
                    <Entry Text="{Binding Equipment}" Placeholder="Varusteet" />
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="Aktiivinen" VerticalTextAlignment="Center" />
                        <Switch IsToggled="{Binding IsActive}" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="10">
                        <Button Text="Uusi" Command="{Binding NewCommand}" BackgroundColor="{StaticResource SecondaryColor}" />
                        <Button Text="Tallenna" Command="{Binding SaveCommand}" />
                        <Button Text="Poista" Command="{Binding DeleteCommand}" BackgroundColor="{StaticResource DangerColor}" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Frame>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Mökit" FontAttributes="Bold" FontSize="18" />
                    <CollectionView ItemsSource="{Binding Cottages}" SelectedItem="{Binding SelectedCottage}" SelectionMode="Single">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Padding="12" Margin="0,0,0,10">
                                    <VerticalStackLayout>
                                        <Label Text="{Binding Name}" FontAttributes="Bold" />
                                        <Label Text="{Binding NightlyPrice, StringFormat='{}{0:F2} € / yö'}" TextColor="{StaticResource SecondaryColor}" />
                                        <Label Text="{Binding Equipment}" FontSize="12" TextColor="{StaticResource MutedTextColor}" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
