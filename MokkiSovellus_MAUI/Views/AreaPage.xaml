<ContentPage
    x:Class="MokkiSovellus_MAUI.Views.AreaPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">
            <Label Text="Alueiden hallinta"
                   FontSize="26"
                   FontAttributes="Bold" />

            <Frame CornerRadius="18" Padding="14" BorderColor="#DDDDDD">
                <VerticalStackLayout Spacing="10">
                    <Entry Placeholder="Alueen nimi"
                           Text="{Binding AreaName}" />

                    <HorizontalStackLayout Spacing="10">
                        <Button Text="Tallenna" Command="{Binding SaveCommand}" />
                        <Button Text="Tyhjennä" Command="{Binding ClearCommand}" />
                        <Button Text="Poista" Command="{Binding DeleteCommand}" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <CollectionView ItemsSource="{Binding Areas}"
                            SelectionMode="Single"
                            SelectedItem="{Binding SelectedArea}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame CornerRadius="16" Padding="12" Margin="0,0,0,10">
                            <Label Text="{Binding Name}" FontSize="18" />
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>